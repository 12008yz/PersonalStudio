<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ScreenRecorder_App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ScreenRecorder_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        This is the main content area of your application.
        Add your UI elements here — for example, controls, layouts, and data-bound views.
        Use 'dotnet new winui-page' to create additional pages and navigate to them via
        the Frame in MainWindow (RootFrame).
    -->
    <ScrollViewer>
        <StackPanel
            Margin="24"
            Spacing="12"
            MaxWidth="720">
            <TextBlock
                x:Uid="MainPage_Header"
                Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock x:Uid="MainPage_Subtitle" TextWrapping="WrapWholeWords" />
            <Button
                x:Uid="MainPage_RecordButton"
                HorizontalAlignment="Left"
                IsEnabled="False" />
        </StackPanel>
    </ScrollViewer>
</Page>
