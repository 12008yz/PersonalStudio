<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ScreenRecorder_App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ScreenRecorder_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="MainPage_Loaded">

    <!--
        This is the main content area of your application.
        Add your UI elements here — for example, controls, layouts, and data-bound views.
        Use 'dotnet new winui-page' to create additional pages and navigate to them via
        the Frame in MainWindow (RootFrame).
    -->
    <ScrollViewer>
        <StackPanel
            Margin="24"
            Spacing="12"
            MaxWidth="720">
            <TextBlock
                x:Uid="MainPage_Header"
                Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock x:Uid="MainPage_Subtitle" TextWrapping="WrapWholeWords" />
            <Button
                x:Uid="MainPage_RecordButton"
                HorizontalAlignment="Left"
                IsEnabled="False" />
            <Button
                x:Name="CaptureTestButton"
                x:Uid="MainPage_CaptureTestButton"
                HorizontalAlignment="Left"
                Click="CaptureTestButton_Click" />

            <TextBlock
                x:Uid="MainPage_ActivityLogHeader"
                Margin="0,16,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}" />
            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <ItemsControl
                    x:Name="ActivityLogItems"
                    MaxHeight="200">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
