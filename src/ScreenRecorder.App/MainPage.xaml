<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ScreenRecorder_App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ScreenRecorder_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="MainPage_Loaded">

    <!--
        This is the main content area of your application.
        Add your UI elements here — for example, controls, layouts, and data-bound views.
        Use 'dotnet new winui-page' to create additional pages and navigate to them via
        the Frame in MainWindow (RootFrame).
    -->
    <ScrollViewer>
        <StackPanel
            Margin="24"
            Spacing="12"
            MaxWidth="720">
            <TextBlock
                x:Uid="MainPage_Header"
                Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock x:Uid="MainPage_Subtitle" TextWrapping="WrapWholeWords" />
            <Button
                x:Uid="MainPage_RecordButton"
                HorizontalAlignment="Left"
                IsEnabled="False" />
            <Button
                x:Name="CaptureTestButton"
                x:Uid="MainPage_CaptureTestButton"
                HorizontalAlignment="Left"
                Click="CaptureTestButton_Click" />

            <TextBlock
                x:Uid="MainPage_AudioSection"
                Margin="0,8,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock x:Uid="MainPage_MicrophoneLabel" />
            <ComboBox
                x:Name="MicrophoneCombo"
                MinWidth="360"
                MaxWidth="640"
                HorizontalAlignment="Stretch"
                DisplayMemberPath="DisplayLabel"
                SelectionChanged="AudioDeviceCombo_SelectionChanged" />
            <TextBlock x:Uid="MainPage_LoopbackLabel" />
            <ComboBox
                x:Name="LoopbackCombo"
                MinWidth="360"
                MaxWidth="640"
                HorizontalAlignment="Stretch"
                DisplayMemberPath="DisplayLabel"
                SelectionChanged="AudioDeviceCombo_SelectionChanged" />
            <TextBlock
                x:Uid="MainPage_DualAudioHint"
                Margin="0,4,0,0"
                TextWrapping="WrapWholeWords"
                Opacity="0.85" />
            <Button
                x:Name="DualAudioTestButton"
                x:Uid="MainPage_DualAudioTestButton"
                HorizontalAlignment="Left"
                Click="DualAudioTestButton_Click" />

            <TextBlock
                x:Uid="MainPage_ActivityLogHeader"
                Margin="0,16,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}" />
            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <ScrollViewer
                    MaxHeight="240"
                    HorizontalScrollMode="Disabled"
                    VerticalScrollMode="Enabled"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    IsTabStop="True">
                    <ItemsControl x:Name="ActivityLogItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
